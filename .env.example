BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_SHEET_ID=your_google_spreadsheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json
# Comma-separated list of allowed Telegram chat IDs (overrides users.yaml)
# ALLOWED_USERS=123456789,987654321
# Set to "false" to disable AI fallback (100% free mode)
USE_AI_FALLBACK=true
# Free World Cup scores API key — register at https://www.football-data.org/client/register
# FOOTBALL_API_KEY=your_key_here
